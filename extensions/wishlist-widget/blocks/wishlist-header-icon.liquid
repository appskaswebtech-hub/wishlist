{% comment %}
  Wishlist Header Icon — App Embed Block
  Injects a wishlist icon into the store header next to the cart icon.
  Shows a badge with the number of items in the wishlist.
{% endcomment %}

{% if block.settings.enabled %}

<style>
  .wl-header-icon-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }
  .wl-header-icon-link:hover {
    color: {{ block.settings.active_color }};
  }
  .wl-header-icon-link svg {
    width: 22px;
    height: 22px;
  }
  .wl-header-icon-badge {
    position: absolute;
    top: 2px;
    right: 0;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    border-radius: 9px;
    background: {{ block.settings.active_color }};
    color: white;
    font-size: 10px;
    font-weight: 700;
    line-height: 18px;
    text-align: center;
    font-family: -apple-system, BlinkMacSystemFont, sans-serif;
    display: none;
  }
</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  var shop = {{ shop.permanent_domain | json }};
  var proxyUrl = {{ shop.url | json }} + "/apps/wishlist";
  var customerId = {{ customer.id | json }} || localStorage.getItem("wishlist_guest_id");
  var iconStyle = {{ block.settings.icon_style | json }};

  // Build the icon SVG based on style setting
  var svgPaths = {
    heart: '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>',
    bookmark: '<path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>',
    star: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>'
  };
  var svgPath = svgPaths[iconStyle] || svgPaths.heart;

  // Create the icon element
  var link = document.createElement("a");
  link.href = "/apps/wishlist/page";
  link.className = "wl-header-icon-link";
  link.setAttribute("aria-label", "Wishlist");
  link.innerHTML =
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' + svgPath + '</svg>' +
    '<span class="wl-header-icon-badge" id="wl-hdr-badge">0</span>';

  // Find the cart icon area and insert before it
  // These selectors cover Dawn, Debut, Sense, Craft, and most popular themes
  var selectors = [
    "header .header__icons",
    "header .header__icon-list",
    "header .site-header__icons",
    "header .header-icons",
    ".header__heading-wrapper .header__icons",
    ".header .utility-bar",
    "header nav .icons",
    ".shopify-section-header .header__icons",
  ];

  var container = null;
  for (var i = 0; i < selectors.length; i++) {
    container = document.querySelector(selectors[i]);
    if (container) break;
  }

  if (!container) {
    // Fallback: try to find any element containing a cart link inside the header
    var cartLink = document.querySelector('header a[href="/cart"], .header a[href="/cart"]');
    if (cartLink) {
      container = cartLink.parentElement;
    }
  }

  if (container) {
    // Insert before the first cart-related element
    var cartEl = container.querySelector('a[href="/cart"], .header__icon--cart, [data-cart-icon], .cart-icon');
    if (cartEl) {
      container.insertBefore(link, cartEl);
    } else {
      // Prepend to the container
      container.insertBefore(link, container.firstChild);
    }
  } else {
    // Last fallback: fixed position top-right
    link.style.position = "fixed";
    link.style.top = "14px";
    link.style.right = "100px";
    link.style.zIndex = "9999";
    link.style.background = "rgba(255,255,255,0.95)";
    link.style.borderRadius = "50%";
    link.style.boxShadow = "0 2px 8px rgba(0,0,0,0.12)";
    document.body.appendChild(link);
    return;
  }

  // Update badge with wishlist count
  if (customerId) {
    fetch(proxyUrl + "/api/wishlist?shop=" + encodeURIComponent(shop) + "&customerId=" + encodeURIComponent(customerId) + "&action=count")
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var badge = document.getElementById("wl-hdr-badge");
        if (data.count > 0 && badge) {
          badge.textContent = data.count > 99 ? "99+" : data.count;
          badge.style.display = "block";
        }
      })
      .catch(function() {});
  }
});
</script>

{% endif %}

{% schema %}
{
  "name": "Wishlist Icon",
  "target": "body",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Enable wishlist icon in header",
      "default": true
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "Icon style",
      "options": [
        { "value": "heart", "label": "Heart" },
        { "value": "bookmark", "label": "Bookmark" },
        { "value": "star", "label": "Star" }
      ],
      "default": "heart"
    },
    {
      "type": "color",
      "id": "active_color",
      "label": "Badge color",
      "default": "#e74c6f"
    }
  ]
}
{% endschema %}
